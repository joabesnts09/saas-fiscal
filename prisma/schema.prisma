
// Multi-tenant SaaS para contadores
// Account = escritório contábil
// Client = empresa do contador (cliente)
// User = usuário do escritório

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                  String   @id @default(uuid())
  name                String   // Nome do escritório contábil
  cnpj                String?  // CNPJ do escritório
  plan                String   @default("free") // free, pro, enterprise
  stripeCustomerId    String?  // ID do cliente no Stripe
  stripeSubscriptionId String? // ID da assinatura ativa
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  users   User[]
  clients Client[]
}

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  password        String?   // bcrypt hash (null para OAuth)
  name            String
  image           String?   // avatar do Google
  role            String    @default("user") // admin, user, superadmin
  accountId       String
  emailVerifiedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
}

model VerificationCode {
  id        String   @id @default(uuid())
  email     String
  code      String
  type      String   // signup
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email, type])
}

model Client {
  id           String   @id @default(uuid())
  name         String   // Nome fantasia ou razão social
  cnpj         String?
  endereco     String?  // Endereço para cabeçalho de exportação
  contato      String?  // Nome do contato
  responsavel  String?  // Nome do responsável
  accountId    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  account       Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  nfeRecords    NfeRecord[]
  prestacao     PrestacaoIncluida[]
  fiscalAlerts  FiscalAlert[]
  exportConfig  ExportConfig?

  @@index([accountId])
}

model ExportConfig {
  id        String   @id @default(uuid())
  clientId  String   @unique
  fieldsJson String  // JSON: string[] - array of field keys in order
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

/// Registro de regras do motor fiscal (CONFAZ, SINIEF, COTEPE, etc.) — peso, severidade e rastreabilidade legal
model TaxRule {
  id              String   @id @default(uuid())
  code            String   @unique // ex: CONF_142_CEST_REQUIRED
  name            String
  description     String?
  category        String // ST | NFE | ICMS | MVA | PROTOCOLO
  legalSource     String? // ex: "Convênio ICMS 142/18", "Ajuste SINIEF X/Y"
  defaultSeverity String // error | warning | info
  weight          Int // impacto no score (pontos a subtrair, ex: 15)
  active          Boolean  @default(true)
  priority        Int      @default(0)
  validatorKey    String? // futuro: nome do validador plugável
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

/// Itens da tabela de ST/CEST (base Convênio ICMS 142/18 e atualizações) — expandir via seed/importação
model ConfazStItem {
  id           String    @id @default(uuid())
  ncmPattern   String // NCM ou prefixo (4 a 8 dígitos), sem máscara
  cest         String // 7 dígitos (comparar normalizado)
  descricao    String?
  segmento     String?
  vigenteDesde DateTime
  vigenteAte   DateTime?
  legalSource  String    @default("Convênio ICMS 142/18")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([ncmPattern])
}

model FiscalAlert {
  id        String   @id @default(uuid())
  clientId  String
  chave     String
  itemIndex Int?     // índice do item (null = alerta da nota inteira)
  productId String?
  tipo      String   // divergencia_icms, cfop_incorreto, ncm_invalido, cest_obrigatorio, etc.
  notaTipo  String?  // venda | compra | outro - tipo da nota fiscal
  descricao String
  nivel     String   // info, warning, error
  detalhes  String?  // JSON
  ruleCode  String?  // código em TaxRule.code (motor plugável)
  legalSource String? // referência normativa exibida no relatório
  createdAt DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([clientId, chave])
  @@index([ruleCode])
}

model NfeRecord {
  id          String   @id @default(uuid())
  chave       String
  numero      String
  serie       String
  dataEmissao String
  valorTotal  Float
  status      String   // Autorizada, Cancelada
  tipo        String   @default("venda") // venda (emitente=empresa), compra (destinatario=empresa), outro
  emitenteJson     String  // JSON: { cnpj, razaoSocial, endereco }
  destinatarioJson String? // JSON: { cnpj, razaoSocial, endereco } (opcional)
  itensJson        String  // JSON: NfeItem[]
  clientId    String
  createdAt   DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, chave])
  @@index([clientId])
  @@index([clientId, dataEmissao])
}

model PrestacaoIncluida {
  id        String   @id @default(uuid())
  chave     String
  clientId  String
  createdAt DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, chave])
  @@index([clientId])
}
